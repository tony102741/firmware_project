data/
build/
ghidra_projects/

# Large binary artifacts
*.zip
*.img
*.bin
*.tar
*.tar.gz
*.tar.xz

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Git history
.git/
.gitignore

# macOS metadata
.DS_Store
**/.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Docs that don't affect the image
*.md
docs/
